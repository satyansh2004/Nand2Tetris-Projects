CHIP Mux4Way16 {
    IN a[16], b[16], c[16], d[16], sel[2];
    OUT out[16];
    
    PARTS:
    
    //OR Gate
    Or(a=sel[0], b=sel[1], out=x);

    //AND Gate
    And(a=sel[1], b=sel[0], out=y);

    //16 BIT MUX
    Mux16(a=a, b=a, sel=x, out=ab);
    Mux16(a=c, b=d, sel=y, out=cd);

    Mux16(a=ab, b=cd, sel=sel[0], out=out);
}